@inject MI.PIMS.UI.Services.MIAuthenticate.IMIAuthenticateService _miAuthenticateService
@inject MI.PIMS.UI.Common.Helper _helper
@using MI.PIMS.UI.Common

@using Kendo.Mvc.UI
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/DPOC/Detail.css" asp-append-version="true" />
<script src="~/js/DPOC/DPOC_Search.js" asp-append-version="true"></script>


<style type="text/css">
    .search-section {
        font-size: 12px;
    }

    .k-dropdown .k-dropdown-wrap {
        border-color: #e4e7eb;
        color: #212529;
        background-color: white;
        transition: color .2s ease,background-color .2s ease,border-color .2s ease,box-shadow .2s ease;
    }

    .k-grid-content {
        min-height: 200px;
    }

    .date-border {
        border: solid 1px #BDBDBD;
        margin-left: 2px;
        margin-right: 2px;
        margin-top: -8px;
        padding: 8px;
    }

    #btnAdvancedSearch:hover {
        background-color: #F2F2F2
    }

    .k-input.k-invalid.valid-override:focus-within {
        box-shadow: 0 0 0 0.25rem rgba(27, 110, 194, 0.25);
    }

    /*Override invalid border color which is not required here.
            User Story 128873 MFQ 4/28/2025
        */
    .k-datepicker .k-picker-wrap.k-invalid, .k-timepicker .k-picker-wrap.k-invalid {
        color: inherit;
        border-color: rgba(0, 0, 0, 0.08) !important;
    }
</style>

@{
    var _UserInfo_T_Dto = (MI.PIMS.BO.Dtos.UserInfo_T_Dto)_miAuthenticateService.UserInfo_T_Dto(_helper.MS_ID);
    var s = _UserInfo_T_Dto.APP_ROLEIDS;
    string[] appRoles = s.Split(',');
}

<div class="breadcrumb-background">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb breadcrumb-background">
                <li class="breadcrumb-item"><a>@Html.ActionLink("Home", "index", "/", new { Area = "" }, new { @class = "breadcrumb-item-font" })</a></li>
                <li class="breadcrumb-item active" style="color: black !important; cursor: initial;" aria-current="page">DPOC Search</li>
            </ol>
        </nav>
    </div>
</div>


<div class="container  search-section" style="padding-left:30px; padding-right:30px;">
    <form id="searchForm">
        <div class="section-heading">
            <div class="row">
                <div class="col-10" style="font-size: 14px;">
                    DPOC Search
                </div>
                <div class="col-2 text-right" style="font-size: 14px;">
                    <div data-toggle="tooltip" title="Toggle the switch to Include Historical records in your search.">
                        <span>Include Historical Records</span> &nbsp;
                        @(Html.Kendo().Switch()
                            .Name("switch")
                            .Events(ev => ev.Change("DPOC_SearchController.switch.onChange"))
                            .HtmlAttributes(new { style = "width: 100%" })
                            .Messages(c => c.Checked("YES").Unchecked("NO"))
                            )
                        <input type="hidden" readonly id="txtIncludeHistorical" />

                    </div>
                </div>
            </div>
        </div>
        <div class="section-border">

            <!-- New Filters -->
            <!-- Row 1 -->
            <div class="form-row">
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="txtDPOCID">DPOC ID:</label>  <label for="txtDPOCID" style="color:red; font-style:italic;"> (Case Sensitive) </label> </b>
                    <input type="text" class="form-control" id="txtDPOCID" value="" maxlength="100">
                </div>

                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="txtLOB">Business Segment:</label></b>
                    <input type="hidden" class="form-control" id="txtLOB" value="">
                    <input type="hidden" class="form-control" id="txtLOBFilterText" value="">

                    @(Html.Kendo().MultiSelect()
                        .Name("msLOB")
                        .DataTextField("CD")
                        .DataValueField("Desc")
                        .Placeholder("Type or Click for Dropdown")
                        .Filter(FilterType.Contains)
                        .Events(e =>
                        {
                            e.DataBound("onDatabound_MultiSelect").Change("DPOC_SearchController.multiSelect.onChange_LOB");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetBusSegCd", "DPOCHierarchyCodes", new { Area = "DPOC" });
                            })
                            .ServerFiltering(false);
                        })
                        )

                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="txtEntity">Entity:</label></b>
                    <input type="hidden" class="form-control" id="txtEntity" value="">
                    <input type="hidden" class="form-control" id="txtEntityFilterText" value="">
                    @(Html.Kendo().MultiSelect()
                        .Name("msEntity")
                        .DataTextField("CD")
                        .DataValueField("Desc")
                        .Placeholder("Type or Click for Dropdown")
                        //.AutoClose(false)
                        .Filter(FilterType.Contains)
                        .TagMode(MultiSelectTagMode.Multiple)
                        .Events(e =>
                        {
                            e.DataBound("onDatabound_MultiSelect").Change("DPOC_SearchController.multiSelect.onChange_ENTITY");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetEntityCd", "DPOCHierarchyCodes", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.ENTITY");
                            })
                            .ServerFiltering(false);
                        })
                        )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="msProduct">Product:</label></b>
                    @(Html.Kendo().MultiSelect()
                        .Name("msProduct")
                        .Placeholder("Type or Click for Dropdown")
                        .Filter(FilterType.Contains)
                        .TagMode(MultiSelectTagMode.Multiple)
                        .Events(e =>
                        {
                            e.DataBound("onDatabound_MultiSelect").Change("DPOC_SearchController.multiSelect.onChange_PRODUCT");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetProductCd", "DPOCHierarchyCodes", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.PRODUCT");
                            })
                            .ServerFiltering(false);
                        })
                        )

                </div>
                <div class="form-group col-sm-3 col-md-3 col-lg-3">
                    <b><label for="txtProcedureCode">Procedure Code:</label>  <label for="txtProcedureCodeText" style="color:red; font-style:italic;"> (Case Sensitive) </label></b>
                    <input type="text" class="form-control" id="txtProcedureCodeText" />
                </div>

                <div class="form-group col-sm-2 col-md-2 col-lg-2">

                    <b><label for="ddlIQGuidelineID">IQ Guideline ID:</label></b>
                    <input type="hidden" readonly id="txtIQGuidelineID" />
                    <input type="hidden" readonly id="txtIQGuidelineIDFilterText" />

                    @(Html.Kendo().DropDownList()
                        .Name("ddlIQGuidelineID")
                        .DataTextField("IQ_GDLN_ID")
                        .DataValueField("IQ_GDLN_ID")
                        .OptionLabel("Type at least 3 Characters for Drop Down")
                        .Filter(FilterType.Contains)
                        .MinLength(3)
                        .HtmlAttributes(new { style = "width: 100%" })
                        .Events(e =>
                        {
                            e.DataBound("DPOC_SearchController.dropdown.onDatabound_IQGuidelineID");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetGuideLineIds", "GuidelineSummary", new { Area = "DPOC" });
                            })
                            .ServerFiltering(true); // Must be true for filtering to work
                        })
                    )
                </div>

                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="msIQVersion">IQ Version:</label></b>
                    <input type="hidden" readonly id="txtIQVersion" />
                    <input type="hidden" readonly id="txtIQVersionFilterText" />
                    @(Html.Kendo().DropDownList()
                        .Name("ddlIQVersion")
                        .DataTextField("IQ_GDLN_VERSION")
                        .DataValueField("IQ_GDLN_VERSION")
                        .OptionLabel("Type at least 3 Characters for Drop Down")
                        .Filter(FilterType.Contains)
                        .MinLength(3)
                        .HtmlAttributes(new { style = "width: 100%" })
                        .Events(e =>
                        {
                            e.DataBound("DPOC_SearchController.dropdown.onDatabound_IQVersion"); //
                        })
                        .DataSource(source =>
                        {
                            source
                            .Ajax()
                            .Read("GetGuideLineVersions", "GuidelineSummary", new { Area = "DPOC" })
                            .PageSize(20);
                        })
                        .Virtual(v => v.ItemHeight(26).ValueMapper("DPOC_SearchController.dropdown.IQ_GDLN_VERSIONValueMapper"))
                    )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="msIQCriteria">IQ Criteria:</label></b>
                    <input type="hidden" readonly id="txtIQCriteria" />
                    @(
                        Html.Kendo().MultiSelect()
                        .Name("msIQCriteria")
                        .DataTextField("VV_CD")
                        .DataValueField("VV_CD_DESC")
                        .Placeholder("Type or Click for Dropdown")
                        .Filter(FilterType.Contains)
                        .Events(e =>
                        {
                            e.DataBound("onDatabound_MultiSelect").Change("DPOC_SearchController.multiSelect.onChange_IQ_CRITERIA");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetPIMSValidValues", "Home", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.IQ_CRITERIAs"); //User Story 128794 MFQ
                            })
                            .ServerFiltering(false);
                        })
                        )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="msIQReference">IQ Reference:</label></b>
                    <input type="hidden" readonly id="txtIQReference" />
                    <input type="hidden" readonly id="txtIQReferenceFilterText" />
                    @(Html.Kendo().MultiSelect()
                        .Name("msIQReference")
                        .DataTextField("IQ_GDLN_NM")
                        .DataValueField("IQ_GDLN_NM")
                        .Placeholder("Type at least 3 Characters for Drop Down")
                        .Filter(FilterType.Contains)
                        .Events(e =>
                        {
                            e.DataBound("DPOC_SearchController.multiSelect.onDatabound_IQ_REFERENCE");//.Change("DPOC_SearchController.multiSelect.onChange_IQ_REFERENCE");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetGuideLineRulesList", "GuidelineSummary", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.IQ_REFERENCE");
                            })
                            .ServerFiltering(false);
                        })
                        )
                </div>

            </div>
            <!-- Row 2 -->
            <div class="form-row">
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="dpDPOCStartDate">DPOC Start Date:</label></b>
                    @(Html.Kendo().DatePicker()
                        .Name("dpDPOCStartDate")
                        //.Value("")
                        .Format("MM/dd/yyyy")
                        .ParseFormats(new string[] {"MMddyyyy",
                            "MMddyy",
                            "MM.dd.yyyy",
                            "MM.dd.yy",
                            "MM.d.yyyy",
                            "M.d.yy",
                            "M.d.yyyy",
                            "MM/dd/yyyy",
                            "MM/dd/yy",
                            "MM/d/yyyy",
                            "M/d/yy",
                            "M/d/yyyy",
                            "MM-dd-yyyy",
                            "MM-dd-yy",
                            "MM-d-yyyy",
                            "M-d-yy",
                            "M-d-yyyy"
                        })
                        .HtmlAttributes(new { style = "width: 100%;", title = "datepicker", @class = "form-to-update" })
                    )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
