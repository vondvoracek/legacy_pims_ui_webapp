                                .ServerFiltering(true);
                            })
                            )
                    </div>
                    <div class="form-group col-sm-2 col-md-2 col-lg-2">
                        <b><label for="msFundingArrangment">Funding Arrangement:</label></b>
                        @(Html.Kendo().MultiSelect()
                            .Name("msFundingArrangment")
                            .Placeholder("Type or Click for Dropdown")
                            .Filter(FilterType.Contains)
                            .TagMode(MultiSelectTagMode.Multiple)
                            .Events(e =>
                            {
                                e.DataBound("onDatabound_MultiSelect").Change("DPOC_SearchController.multiSelect.onChange_FUNDING_ARRANGEMENT");
                            })
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                    read.Action("GetFundingArrangement", "DPOCHierarchyCodes", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.FUNDING_ARRANGEMENT");
                                })
                                .ServerFiltering(false);
                            })
                        )
                </div>
                </div>
                <!-- Row 5 -->
                <div class="form-row">

                    <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    </div>
                    <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    </div>
                </div>

            </div>
            <br />

            <div class="form-row">

                <div class="form-group col-md-12 col-sm-12 col-lg-12 text-center">

                    <button id="btnSearch"  type="submit" class="btn btn-primary noSubmit" title="Click to search records!"><i class="fas fa-search"></i> Search </button>
                    <button id="btnReset" type="button" class="btn btn-outline-primary noSubmit" title="Click to reset filters!"><i class="fas fa-times"></i> Reset </button>
                    @if (_UserInfo_T_Dto != null)
                    {
                        if (appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.DPOCReadWrite))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.DPOCAdmin))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.SuperAdmin))
                        )
                        {
                            <button id="btnAddNew" type="button" class="btn btn-primary noSubmit" data-toggle="modal" data-target="#addNewModal" data-backdrop="static" data-keyboard="false" title="Click to go Add New!"><i class="fas fa-plus-circle"></i> Add New </button>
                        }

                    }

                </div>
            </div>
        </div>
    </form>
    <br />
    <div style="font-size:11px !important;">
        @(Html.Kendo().Grid<MI.PIMS.BO.Dtos.DPOC_Inventories_V_Dto>()
            .Name("grid_Search")
            .Columns(c =>
            {
                c.Bound(p => p.DPOC_HIERARCHY_KEY)
                .Title("DPOC ID")
                .ClientTemplate(
                "<a href='javascript:void(0);' style='color:blue;' onclick=\"DPOC_SearchController.methods.redirect('#=DPOC_HIERARCHY_KEY#,#=kendo.toString(kendo.parseDate(DPOC_VER_EFF_DT),'MM-dd-yyyy hh:mm:ss tt')#,#=DPOC_PACKAGE#');\" title='Click to view details!' \\data-target='tooltip'\\>#= DPOC_HIERARCHY_KEY # </a>" +
                ((appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.DPOCReadWrite))
                || (appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.DPOCAdmin))
                || (appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.SuperAdmin))))
                ) ? "#if(IS_CURRENT == 'Y'){# <i class=\"edit-epal-icon k-icon k-i-pencil text-primary float-right\" onclick=\"DPOC_SearchController.methods.redirect_edit('#=DPOC_HIERARCHY_KEY#, #=kendo.toString(kendo.parseDate(DPOC_VER_EFF_DT),'MM-dd-yyyy hh:mm:ss tt')#,#=DPOC_PACKAGE#');\" title='Click to edit details!' \\data-target='tooltip'\\></i> #}#" : "")
                )
                .Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                .HtmlAttributes(new { style = "text-align: center" })
                .Width(200);
                c.Bound(p => p.PROC_CD).Title("Proc<br />Code").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(85);
                c.Bound(p => p.DPOC_EFF_DT).Filterable(false)
                .Title("DPOC<br/>Start Date")
                .ClientTemplate("#= ( kendo.toString(kendo.parseDate(DPOC_EFF_DT), 'MM/dd/yyyy') == '12/31/2999' || (data.DPOC_EFF_DT == null)) ? ' ' : kendo.toString(kendo.parseDate(DPOC_EFF_DT), 'MM/dd/yyyy') #")
                .HtmlAttributes(new { style = "text-align: center" })
                .HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                .Width(100);
                c.Bound(p => p.DPOC_PACKAGE).Title("DPOC Package").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(150);
                //c.Bound(p => p.DPOC_RELEASE).Title("DPOC Release").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
                c.Bound(p => p.DPOC_ELIGIBLE_IND).Title("DPOC Eligible").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(80);
                c.Bound(p => p.DPOC_IMPLEMENTED_IND).Title("DPOC Implemented").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(150);
                c.Bound(p => p.DPOC_VER_EFF_DT).Filterable(false)
                .Title("DPOC Ver <br />Eff Date")
                .ClientTemplate("#= (data.DPOC_VER_EFF_DT == null) ? ' ' : kendo.toString(kendo.parseDate(DPOC_VER_EFF_DT), 'MM/dd/yyyy hh:mm:ss tt') #")
                .HtmlAttributes(new { style = "text-align: center" })
                .HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                .Width(150);
            })
            .Resizable(resize => resize.Columns(true))
            .HtmlAttributes(new { style = "height: 100%" })
            .Sortable()
            .Events(e => e.ExcelExport("DPOC_SearchController.grid.excelExport"))
            .NoRecords()
            .Navigatable()
            .ToolBar(tools => tools.Excel())
            .Pageable(pageable => pageable
            .Refresh(true)
            .PreviousNext(true)
            .Numeric(true)
            )
            .AutoBind(false)
            .Scrollable()
            .Selectable()
            .Filterable()
            .Excel(excel => excel
            .AllPages(true)
            .FileName("ExportExcel.xlsx")
            .Filterable(true)
            .ProxyURL(Url.Action("Excel_Export_Save", "Grid"))
            )
            .DataSource(dataSource => dataSource
            .Ajax()
            .PageSize(100)
            .Read(read => read.Action("GetDPOCSearch", "Home").Data("DPOC_SearchController.grid.param"))
            .Events(ev => ev.RequestEnd("DPOC_SearchController.grid.onGridRequestEnd"))
            )
            )
    </div>


</div>

