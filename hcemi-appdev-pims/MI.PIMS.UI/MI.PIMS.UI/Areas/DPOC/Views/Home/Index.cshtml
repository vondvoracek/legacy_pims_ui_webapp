                                read.Action("GetDPOCRelease", "DPOCInventories", new { Area = "DPOC" });
                            })
                            .ServerFiltering(false);
                        })
                        )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="txtDPOCEligible">DPOC Eligible:</label></b>
                    <input type="hidden" readonly id="txtDPOCEligible" />
                    <input type="hidden" readonly id="txtDPOCEligibleFilterText" />

                    @(Html.Kendo().DropDownList() //User Story 128868 MFQ 3/3/2025
                        .Name("msDPOCEligible")
                        .DataTextField("VV_CD_DESC")
                        .DataValueField("VV_CD")
                        .HtmlAttributes(new { style = "width: 100%", @class = "form-to-update" })
                        .OptionLabel("Type or Click for Dropdown")
                        .Events(e =>
                        {
                            e.DataBound("onDatabound_DropDown").Change("DPOC_SearchController.multiSelect.onChange_DPOCEligible");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetPIMSValidValues", "Home", new { Area = "EPAL" }).Data("DPOC_SearchController.dropdown.param.DPOC_ELIGIBLE_IND");
                            })
                            .ServerFiltering(false);
                        })
                        )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="txtDPOCImplemented">DPOC Implemented:</label></b>
                    <input type="hidden" readonly id="txtDPOCImplemented" />
                    <input type="hidden" readonly id="txtDPOCImplementedFilterText" />
                    @(Html.Kendo().MultiSelect()
                        .Name("msDPOCImplemented")
                        .DataTextField("VV_CD_DESC")
                        .DataValueField("VV_CD")
                        .Placeholder("Type or Click for Dropdown")
                        .HtmlAttributes(new { style = "width: 100%", @class = "form-to-update" })
                        .Events(e =>
                        {
                            e.DataBound("onDatabound_MultiSelect").Change("DPOC_SearchController.multiSelect.onChange_DPOCImplemented");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetPIMSValidValues", "Home", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.DPOC_IMPLEMENTED_IND");
                            })
                            .ServerFiltering(false);
                        })
                        )

                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="msPAStatus">DPOC Version Eff Date:</label></b>
                    @(Html.Kendo().DatePicker()
                        .Name("dpDPOCVerEffDate")
                        //.Value("")
                        .Format("MM/dd/yyyy")
                        .ParseFormats(new string[] {
                            "MMddyyyy",
                            "MMddyy",
                            "MM.dd.yyyy",
                            "MM.dd.yy",
                            "MM.d.yyyy",
                            "M.d.yy",
                            "M.d.yyyy",
                            "MM/dd/yyyy",
                            "MM/dd/yy",
                            "MM/d/yyyy",
                            "M/d/yy",
                            "M/d/yyyy",
                            "MM-dd-yyyy",
                            "MM-dd-yy",
                            "MM-d-yyyy",
                            "M-d-yy",
                            "M-d-yyyy"
                        })
                        .HtmlAttributes(new { style = "width: 100%; padding-left: 5px;padding-right: 5px;", title = "datepicker", @class = "form-to-update valid-null" })
                    )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <div>
                        <a id="btnAdvancedSearch" class="btn btn-md" href="#"><i id="icon-up" class="fas fa-chevron-up"></i> <i id="icon-down" class="fas fa-chevron-down"></i> Advanced Search</a>
                    </div>
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                </div>
            </div>
            <!-- Row 4 -->
            <div id="divAdvancedSearch">
                <!--============================
                    Start Advanced Search Here
                ===============================-->
                <div class="form-row">
                    <div class="form-group col-sm-2 col-md-2 col-lg-2">
