                        .Events(e =>
                        {
                            e.DataBound("onDatabound_MultiSelect");//.Change("DPOC_SearchController.multiSelect.onChange_DPOC_PACKAGE");
                        })
                        .DataSource(source =>
                        {
                            source.Read(read =>
                            {
                                read.Action("GetPIMSValidValues", "Home", new { Area = "DPOC" }).Data("DPOC_SearchController.multiSelect.param.DPOC_PACKAGE");
                            })
                            .ServerFiltering(false);
                        })
                        )
                </div>
                <div class="form-group col-sm-2 col-md-2 col-lg-2">
                    <b><label for="txtDPOCRelease">DPOC Release:</label></b>
                    <input type="hidden" readonly id="txtDPOCRelease" />
                    <input type="hidden" readonly id="txtDPOCReleaseFilterText" />
                    @(Html.Kendo().MultiSelect()
                        .Name("msDPOCRelease")
                        .Placeholder("Type or Click for Dropdown")
                        .Filter(FilterType.Contains)
                        .TagMode(MultiSelectTagMode.Multiple)
                        .Events(e =>
