                            <label for="msOutpatientRuleTypeOutcome">
                                Outpatient Rule Type Outcome:
                            </label>
                        </b>
                        <input type="hidden" readonly id="txtOutpatientRuleTypeOutcome" />
                        <input type="hidden" readonly id="txtOutpatientRuleTypeOutcomeFilterText" />
