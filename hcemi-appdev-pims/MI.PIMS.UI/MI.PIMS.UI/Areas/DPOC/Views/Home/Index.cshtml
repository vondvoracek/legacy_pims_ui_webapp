                    <div class="form-group col-sm-2 col-md-2 col-lg-2">
                        <b><label for="msJurisdiction">Jurisdiction:</label></b>
                        <input type="hidden" readonly id="txtJurisdiction" />
                        <input type="hidden" readonly id="txtJurisdictionFilterText" />
                        <!-- 27 -->
                        @(
                            Html.Kendo().MultiSelect()
