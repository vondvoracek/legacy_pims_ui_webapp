                    <div class="form-group col-sm-2 col-md-2 col-lg-2">
                        <b>
                            <label for="txtInpatientRuleTypeOutcome">
                                Inpatient Rule Type Outcome:
                            </label>
                        </b>
                        <input type="hidden" readonly id="txtInpatientRuleTypeOutcome" />
                        <input type="hidden" readonly id="txtInpatientRuleTypeOutcomeFilterText" />
                        <!-- 25 -->@*User Story 128890 MFQ 4/29/2025*@
                        @(Html.Kendo().MultiSelect()
                            .Name("msInpatientRuleTypeOutcome")
                            .DataTextField("VV_CD_DESC")
                            .DataValueField("VV_CD_DESC")
                            .Placeholder("Type or Click for Dropdown")
