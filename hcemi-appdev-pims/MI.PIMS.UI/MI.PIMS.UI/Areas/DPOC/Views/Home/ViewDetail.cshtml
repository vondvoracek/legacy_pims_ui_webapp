@model MI.PIMS.BO.Dtos.DPOC_Inventories_V_Dto
@using Kendo.Mvc.UI
@using MI.PIMS.UI.Common
@{
    ViewData["Title"] = "View Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    ViewData["PageType"] = @Roles.DPOCReadOnly.ToString();
    ViewData["DPOCPageView"] = @DPOCPageView.ViewDetail.ToString();
}
<script src="~/js/GridLoadTracker.js" asp-append-version="true"></script>
<script src="~/js/GridAndFormDirtyChecker.js" asp-append-version="true"></script>
<script src="~/js/DPOC/Detail.js" asp-append-version="true"></script>

@if (Model != null)
{
    @Html.Hidden("dpoc-page-type", ViewData["PageType"].ToString())
    @Html.Hidden("dpoc-page-view", ViewData["DPOCPageView"].ToString())
    <div style="height:100%" class="my-form-font">
        <div class="breadcrumb-background">
            <div class="container">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb breadcrumb-background">
                        <li class="breadcrumb-item"><a>@Html.ActionLink("Home", "index", "/", new { Area = "" }, new { @class = "breadcrumb-item-font" })</a></li>
                        <li class="breadcrumb-item"><a>@Html.ActionLink("DPOC Search", "Index", "Home", new { Area = "DPOC" }, new { @class = "breadcrumb-item-font" })</a></li>
                        <li class="breadcrumb-item active" style="color: black !important; cursor: initial;" aria-current="page">View Detail</li>
                                              
                    </ol>
                </nav>
                @if (!String.IsNullOrEmpty(Model.dateErrorString))
                {
                    <div style="width: 99%;text-align: left;white-space: pre-line;font-size:14px;margin-top: -15px;margin-left: 5px;padding-top: 10px;margin-bottom: 9px;padding-bottom: 10px;" class="date-error-string label-tag-red">@Model.dateErrorString</div>
                }
            </div>
        </div>
              
        <partial name="_DetailHeader" model="Model" view-data="ViewData" />
        <partial name="_DetailTabs" model="Model" view-data="ViewData" />
    </div>
    <br />
    <br /> 
}

else
{
    <div class="container">
    <div style="height:100%" class="my-form-font">
        @*@await Html.PartialAsync("_NoRecordsFound")*@
        <partial name="_NoRecordsFound"/>
    </div>
    <br />
    <br />
    </div> 
}

<!--Generic Modal-->
<div class="modal fade bs-dpoc-detail-widget-modal" id="bs-dpoc-detail-widget-modal" tabindex="-1" role="dialog" aria-labelledby="bs-dpoc-detail-widget-modal-label" aria-hidden="true" data-backdrop="static">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="bs-dpoc-detail-widget-modal-title"></h4>
                <button type="button" class="close bs-dpoc-detail-widget-modal-close" data-dismiss="modal">
                    <span aria-hidden="true">×</span>
                </button>
            </div>
            <div class="modal-body">
                Loading...
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default btn-sm bs-dpoc-detail-widget-modal-close" data-dismiss="modal"><i class="fas fa-times"></i> Close</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="~/css/DPOC/Detail.css" asp-append-version="true"/>
<script src="~/js/DPOC/_DPOC_DetailToolTips.js" asp-append-version="true"></script>


<script>
    $(function() {

        // Log User Access Hist for the page and logged in user
        var pims_id = "@Model" != null ? "@Model.DPOC_HIERARCHY_KEY.ToStringNullSafe()" : "";

        UserAccessHistController.add({
            "MODULE_NAME": "DPOC",
            "USERACTION": "DPOC/Home/ViewDetail?pims_id=" + pims_id,
            "USERSELECTION": "DPOC/Home/ViewDetail",
            "LST_UPDT_DT": null,
            "LST_UPDT_BY": MS_ID,
            "PAGE_ID": "30",
            "__RequestVerificationToken": $('meta[name="request-verification-token"]')[0].content
        });
    });
</script>