@model MI.PIMS.BO.Dtos.DPOC_Inventories_V_Dto
@using Kendo.Mvc.UI
@using MI.PIMS.UI.Common
@{
    ViewData["Title"] = "Edit Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/css/DPOC/Detail.css" />
<script src="~/js/GridLoadTracker.js" asp-append-version="true"></script>
<script src="~/js/GridAndFormDirtyChecker.js" asp-append-version="true"></script>
<script src="~/js/DPOC/Detail.js" asp-append-version="true"></script>

<style>

    /*     .k-window,
        .k-overlay {
                z-index: 11000 !important;
        }

        .swal2-container {
                z-index: 10000 !important;
        } */

    .kendo-grid-loading {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255, 255, 255, 0.7);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 16px;
        color:grey;
    }
</style>

@{
    ViewData["PageType"] = @Roles.DPOCReadWrite.ToString();
    ViewData["DPOCPageView"] = @DPOCPageView.EditDetail.ToString();
}

@if (Model != null)
{
    <input id="addnew-record" type="hidden" readonly value="@ViewBag.AddRecord" />
    @Html.Hidden("dpoc-page-view", ViewData["DPOCPageView"].ToString())
    <form id="editForm">
        <div id="myOverlay"></div>
        <div style="height:100%" class="my-form-font">
            <div class="breadcrumb-background">
                <div class="container">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb breadcrumb-background">
                            <li class="breadcrumb-item"><a>@Html.ActionLink("Home", "index", "/", new { Area = "" }, new { @class = "breadcrumb-item-font" })</a></li>
                            <li class="breadcrumb-item"><a>@Html.ActionLink("DPOC Search", "Index", "Home", new { Area = "DPOC" }, new { @class = "breadcrumb-item-font" })</a></li>
                            <li class="breadcrumb-item active" style="color: black !important; cursor: initial;" aria-current="page">Edit Detail</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <partial name="_DetailHeader" model="Model" view-data="ViewData" />
            <partial name="_DetailTabs_AddNew" model="Model" view-data="ViewData" />
        </div>
        <br />
        <br />
    </form>
}

else
{
    <div class="container">
        <div style="height:100%" class="my-form-font">
            <partial name="_NoRecordsFound" />
        </div>
        <br />
        <br />
    </div>
}

<script>
    $(function() {

        // Log User Access Hist for the page and logged in user
        var pims_id = "@Model" != null ? "@Model.DPOC_HIERARCHY_KEY.ToStringNullSafe()" : "";

        UserAccessHistController.add({
            "MODULE_NAME": "DPOC",
            "USERACTION": "DPOC/Home/EditDetail?pims_id=" + pims_id,
            "USERSELECTION": "DPOC/Home/EditDetail",
            "LST_UPDT_DT": null,
            "LST_UPDT_BY": MS_ID,
            "PAGE_ID": "30",
            "__RequestVerificationToken": $('meta[name="request-verification-token"]')[0].content
        });
    });
</script>