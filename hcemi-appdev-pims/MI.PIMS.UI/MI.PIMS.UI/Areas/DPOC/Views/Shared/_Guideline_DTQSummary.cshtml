@using Kendo.Mvc.UI;
@using MI.PIMS.BO.Dtos;

<script src="~/js/DPOC/_DPOC_GuidelineDTQ.js" asp-append-version="true"></script>

<div class="container tab-section">

@(Html.Kendo().Grid<DPOC_INV_DTQS_V_Dto>()
    .Name("grid_dtq")
    .Columns(columns =>
    {
        columns.Bound(d => d.DTQ_IQ_GDLN_ID).Title("Guideline").EditorTemplateName("IQ_GDLN_ID").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;"});
        columns.Bound(d => d.DTQ_POS_APPL).Title("POS").EditorTemplateName("POS_APPLDPOC").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });
        columns.Bound(d => d.DTQ_INCL_EXCL_CD).Title("INCL/EXCL").EditorTemplateName("DTQ_INCL_EXCL_CD").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });
        columns.Bound(d => d.DTQ_NM).Title("DTQ Name").HeaderHtmlAttributes(new { @title = "Maximum length 100 characters", style = "vertical-align:text-top;background:white;font-weight:bold;", @maxlength = "100" });
        columns.Bound(d => d.DTQ_TYPE).Hidden(true);
        columns.Bound(d => d.DTQ_TYPE_DESC).Title("DTQ Type").EditorTemplateName("DTQ_TYPE").ClientTemplate("#:DTQ_TYPE_DESC#").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });
        columns.Bound(d => d.DTQ_RSN_DESC).Title("DTQ Reason").EditorTemplateName("DTQ_RSN").ClientTemplate("#:DTQ_RSN_DESC#").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });
        columns.Bound(d => d.TGT_DTQ).Title("Target DTQ").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });
        columns.Bound(d => d.TGT_DTQ_VERSION).Title("Target DTQ<br/>Version").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });
        columns.Bound(d => d.HOLDING_DTQ).Title("Holding DTQ").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;", @maxlength = 100 });
        columns.Bound(d => d.HOLDING_DTQ_VERSION).Title("Holding DTQ<br/>Version").HeaderHtmlAttributes(new { style = "vertical-align:text-top;background:white;font-weight:bold;" });        
        columns.Bound(d => d.DTQ_RSN).Hidden(true);                            
    })
    .Resizable(resize => resize.Columns(true))
    .HtmlAttributes(new { style = "height: 400px;" })
    .Scrollable()
    .Sortable()
    //.Pageable(pageable => pageable.Refresh(false))
    .Events(events => events.Edit("GSSDTQController.grid.dtq.onEdit").DataBound("GSSDTQController.grid.onDataBound"))
    .DataSource(dataSource => dataSource
    .Ajax()
    .PageSize(100)
    .Read(read => read.Action("GetDPOCInvDTQsByPIMSID", "Home", new { Area = "DPOC" }).Data("GSSDTQController.grid.params"))
    )
)
</div>
