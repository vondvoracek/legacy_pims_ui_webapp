                                c.Bound(p => p.IQ_GDLN_EXP_DT).Title("IQ Expiration Date").ClientTemplate("#= ( kendo.toString(kendo.parseDate(IQ_GDLN_EXP_DT), 'MM/dd/yyyy') == '12/31/2999' || (data.IQ_GDLN_EXP_DT == null)) ? ' ' : kendo.toString(kendo.parseDate(IQ_GDLN_EXP_DT), 'MM/dd/yyyy') #").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(160);                                
