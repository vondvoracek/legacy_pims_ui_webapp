                                c.Bound(p => p.IQ_GDLN_DESC).Title("IQ Guideline<br/>Description").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(160);
                                c.Bound(p => p.IQ_GDLN_ID).Title("IQ Guideline ID").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(160);
