<!--Guideline Modal-->
<div class="bs-dpoc-guideline-summary-widget-modal" id="bs-dpoc-guideline-summary-widget-modal" style="padding:5px;">
    <div class="window-body guideline-modal-body">
        @(
            Html.Kendo().TabStrip()
            .Name("gsTabstrip")
            .TabPosition(TabStripTabPosition.Left)
            .Items(tabstrip =>
            {
                tabstrip.Add().HtmlAttributes(new { id = "tab-gl-summary" }).Selected(true).Text("Guideline Detail")
                .LoadContentFrom("Load_Guideline_Summary_Detail", "Home", new { Areas = "DPOC" });

                tabstrip.Add().Text("Guideline Configuration")
                .LoadContentFrom("Load_Guideline_Configuration", "Home", new { Areas = "DPOC" });

                tabstrip.Add().HtmlAttributes(new { id = "tab-gl-diag" }).Text("Diagnosis Code")
                .LoadContentFrom("Load_Guideline_DiagnosisCodes", "Home", new { Areas = "DPOC" });
            })
            .Events(events => events.ContentLoad("DPOC_GuidelineSummaryController.tab.loaded").Select("DPOC_GuidelineSummaryController.tab.select"))
        )
    </div>
    <div class="window-footer bs-dpoc-guideline-summary-widget-modal-footer">
        <button type="button" class="btn btn-primary btn-sm bs-dpoc-guideline-summary-widget-modal-save d-none"><i class="fas fa-save"></i> Activate</button>
        <button type="button" class="btn btn-default btn-sm bs-dpoc-guideline-summary-widget-modal-close" data-dismiss="modal"><i class="fas fa-times"></i> Close</button>
    </div>
</div>

<div class="dpoc-guideline-summary-hover-window" id="dpoc-guideline-summary-hover-window" style="padding:5px;">
    <div class="window-body guideline-summary-hover-window-body">
    </div>
</div>

