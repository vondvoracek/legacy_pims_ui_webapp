@using Kendo.Mvc.UI
@using MI.PIMS.UI.Common

<script src="~/js/DPOC/_DPOC_GuidelineSummary.js" asp-append-version="true"></script>
<script src="~/js/DPOC/_DPOC_Configuration.js" asp-append-version="true"></script>
<script src="~/js/DPOC/_DPOC_GuidelineDiagnosis.js" asp-append-version="true"></script>
<script src="~/js/DPOC/_DPOC_GuidelineState.js" asp-append-version="true"></script>

@Html.Hidden("GuidelineSummaryDetailUrl", Url.Action("GuidelineSummaryDetailComponent", "Home", new
    {
        Area = "DPOC",
        DPOC_HIERARCHY_KEY = "__DPOC_HIERARCHY_KEY__",
        DPOC_VER_EFF_DT = "__DPOC_VER_EFF_DT__",
        DPOC_PACKAGE = "__DPOC_PACKAGE__",
        DPOC_RELEASE = "__DPOC_RELEASE__",
        IQ_GDLN_ID = "__IQ_GDLN_ID__",
        RULE_OUTCOME_OUTPAT = "__RULE_OUTCOME_OUTPAT__",
        RULE_OUTCOME_OUTPAT_FCLTY = "__RULE_OUTCOME_OUTPAT_FCLTY__",
        RULE_OUTCOME_INPAT = "__RULE_OUTCOME_INPAT__",
        PageType = "__PageType__"
    }))

<style type="text/css">
    tr.highlight {
        background-color: lavender;
    }

    .k-window {
        border: 1px solid rgb(0, 128, 255);
    }


    #grid_guideline_summary .k-pager-info {
        display: inline-block !important;
    }

    #grid_guideline_summary_active .k-pager-info {
        display: inline-block !important;
    }

    #grid_guideline_summary .k-grid-content.k-auto-scrollable {
        height: 314px !important;
    }

    #grid_guideline_summary_active .k-grid-content.k-auto-scrollable {
        height: 314px !important;
    }
</style>

<input type="hidden" id="txtGDLNPopupType" class="gs-fields" />
<input type="hidden" id="txtDataRowId_GS" class="gs-fields" />
@Html.Hidden("txtDPOCRelease_GS_hdn")
@Html.Hidden("txtDPOC_VER_NUM_hdn")
@Html.Hidden("txtIQ_GDLN_ID_GS_hdn")
<div class="container">
    <div class="form-row gdln-header-row" style="padding-top:10px;">
        <div class="col-6">
            
        </div>
        <div class="col-6 text-right">
            <a id="btnAvailableGuidelines" class="btn btn-md" href="javascript:void(0)"><i id="icon-up" class="fas fa-chevron-down color-dark-green" style="font-size:16px;"></i> <i id="icon-down" class="fas fa-chevron-up color-red" style="font-size:16px;"></i> Available Guidelines</a>
        </div>
        <hr />
    </div>
    <div class="row">
        <div class="form-group col-md-12">
            <div class="row" style="font-size:11px !important;">
