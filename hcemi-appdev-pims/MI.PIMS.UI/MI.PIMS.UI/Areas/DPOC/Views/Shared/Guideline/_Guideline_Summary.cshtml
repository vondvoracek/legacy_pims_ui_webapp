                            .Columns(c =>
                            {
                                c.Bound(p => p.IQ_GDLN_STATUS).Title("Current<br/>Status").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold;" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
