                    </div>
                    <label for="txtPlan" class="cell-padding col-lg-1 text-lg-right text-sm-left col-form-label font-modal-weight">Plan:</label>
                    <div class="col-lg-2 cell-padding">
                        <input type="text" data-toggle="tooltip" class="form-control" disabled="disabled" id="txtPlan" name="txtPlan" value="@Model.DPOC_PLAN_CD">
                    </div>
                </div>
                <div class="form-row">
