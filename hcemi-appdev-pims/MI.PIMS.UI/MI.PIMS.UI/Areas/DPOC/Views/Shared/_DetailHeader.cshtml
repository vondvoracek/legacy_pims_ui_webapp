                    </div>
                    <label for="txtFunding" class="cell-padding col-lg-1 text-lg-right text-sm-left col-form-label font-modal-weight">Funding:</label>
                    <div class="col-lg-2 cell-padding">
                        <input type="text" data-toggle="tooltip" class="form-control" disabled="disabled" id="txtFunding" name="txtFunding" value="@Model.DPOC_FUND_ARNGMNT_CD">
                    </div>
                    <label for="txtProcedureCode" class="cell-padding col-lg-1 text-lg-right text-sm-left col-form-label font-modal-weight">Procedure Code:</label>
                    <div class="col-lg-2 cell-padding">
                        <input type="text" data-toggle="tooltip" class="form-control" disabled="disabled" id="txtProcedureCode" name="txtProcedureCode" value="@Model.PROC_CD">
                    </div>
                    <label for="txtDrugName" class="cell-padding col-lg-1 text-lg-right text-sm-left col-form-label font-modal-weight">Drug Name:</label>
                    <div class="col-lg-2 cell-padding">
                        <input type="text" data-toggle="tooltip" class="form-control" disabled="disabled" id="txtDrugName" name="txtDrugName" value="@Model.DRUG_NM">
                    </div>
                </div>
                <div class="form-row">
                    <label for="ddlDPOCPackage" class="cell-padding col-lg-1 text-lg-right text-sm-left col-form-label font-modal-weight required">DPOC Package:</label>
                    <div class="col-lg-2 cell-padding">
                   @*      <input type="text" data-toggle="tooltip" class="form-control" id="txtDPOCPackage" name="txtDPOCPackage" value="@Model.DPOC_PACKAGE"> *@
@*                         @(Html.Kendo().DropDownList() //User Story 128868 MFQ 3/3/2025
                            .Name("ddlDPOCPackage")
                            .HtmlAttributes(new { style = "width: 100%", @class = "form-to-update" })
                            .OptionLabel("Type or Click for Dropdown")
                            .Value(@Model.DPOC_PACKAGE)
                            .Enable(ViewData["Title"].ToString() == "View Detail" ? false: true)
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                    read.Action("GetDPOCPackage", "DPOCInventories", new { Area = "DPOC" });
                                })
                                .ServerFiltering(false);
                            })
                        ) *@

                        @(Html.Kendo().DropDownList() //User Story 128868 MFQ 3/3/2025
                            .Name("ddlDPOCPackage")
                            .DataTextField("VV_CD_DESC")
                            .DataValueField("VV_CD_DESC")
                            .Value(@Model.DPOC_PACKAGE)
                            .HtmlAttributes(new { style = "width: 100%", @class = "form-to-update" })
                            .OptionLabel("Type or Click for Dropdown")
                            //.Enable(ViewData["Title"].ToString() == "View Detail" ? false : true)
                            .DataSource(source =>
                            {
                                source.Read(read =>
                            {
                                                read.Action("GetPIMSValidValues", "Home", new { Area = "DPOC" }).Data("DetailController.dropdown.param.DPOC_PACKAGE_2");
                            })
                            .ServerFiltering(false);
                            })
                            )
                    </div>
                    <label for="txtDPOCVersionDt" class="cell-padding col-lg-1 text-lg-right text-sm-left col-form-label font-modal-weight">DPOC Version Eff Date:</label>
                    <div class="col-lg-2 cell-padding">
                        <input type="text" data-toggle="tooltip" class="form-control" disabled="disabled" id="txtDPOCVersionDt" name="txtDPOCVersionDt" value="@Model.DPOC_VER_EFF_DT">
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<script>
    $(document).ready(function () {
        const headerContainer = document.getElementsByClassName("container search-section")[0];
        const buttons = headerContainer.querySelectorAll("button")
        buttons.forEach(button => {
            button.addEventListener('click', (event) => {
                const appInsightsClient = new TelemetryLogger();
                var pageView = $(document).find('#dpoc-page-view').first().get(0).value.toLowerCase();
                var pageType;
                switch(pageView){
                    case "adddetail":
                        pageType = "DPOCAdd";
                        break;
                    case "editdetail":
                        pageType = "DPOCEdit";
                        break;
                    case "addnew":
                        pageType = "DPOCNew";
                        break;
                    case "duplicaterecorddetail":
                        pageType = "DPOCDuplicate";
                        break;
                    case "viewdetail":
                    default:
                        pageType = "DPOCView";
                }
                if(appInsightsClient.isAppInsightsEnabled("Client." + pageView)) {
                    var buttonStr = event.target.innerText;
                    const logProperties = new LogInfo(event.target.id, MS_ID, pageType + " " + buttonStr + " Tab click");
                    appInsightsClient.trackEvent('Client.' + pageType + '.' + buttonStr.replaceAll(' ', ''), logProperties);
                }
            });
        });
    });
</script>

@if (ViewBag.ShowDeleteButton != false)
{
    @await Html.PartialAsync("_DeleteModal")
}
