<input type="hidden" id="EPAL_EXP_DT" class="EPAL_EXP_DT" value="@Model.OVERALL_EXP_DT"/>

<div class="container tab-section">
    <h5>
        EPAL Summary
    </h5>     
    <hr />
    <!-- Row 1 -->
    <div class="form-row my-row-padding">
        <label for="txtCodeStatus" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Procedure Code Status:</label>
        <div id="divCodeStatus" class="col-lg-3" data-toggle="tooltip">
            @*<input type="text" data-toggle="tooltip" class="form-control" id="txtCodeStatus" value="@Model.PROC_CD_STATUS" readonly="readonly">*@
            <span style="height: 25px; display: inline-block; vertical-align: text-bottom; width: 100%; padding-top: 5px;" class="procedure-code-status label-tag-@(@Model.PROC_CD_STATUS == "Valid" ? "green": (@Model.PROC_CD_STATUS == null ? "": "red"))">@Model.PROC_CD_STATUS</span>
        </div>
        <div class="col-lg-3"></div>
        <div class="col-lg-2"></div>
    </div>
    <!-- Row 2 -->
    <div class="form-row my-row-padding">
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">HCEMI Reporting Category:</label>
        <div class="col-lg-3">
            <input type="text"  data-toggle="tooltip" class="form-control" id="txtStandardCategory" value="@Model.STNDRD_SVC_CAT" readonly>
        </div>

        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">HCEMI Reporting Subcategory:</label>
        <div class="col-lg-3">
            <input type="text"  data-toggle="tooltip" class="form-control" id="txtStandardSubCategory" value="@Model.STNDRD_SVC_SUBCAT" readonly>
        </div>
    </div>
    <!-- Row 3 -->
    <div class="form-row my-row-padding">
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight @(String.IsNullOrEmpty(@Model.STNDRD_SVC_CAT) ? "required": "")"> Alternate Category: </label>
        <div class="col-lg-3">
            <input type="hidden" id="ddlAlternateCategoryOrignal" value="@Model.ALTRNT_SVC_CAT" />
            @*<input type="text"  data-toggle="tooltip" class="form-control" id="txtAlternateCategory" value="@Model.ALTRNT_SVC_CAT" readonly />*@
            @(Html.Kendo().DropDownList()
                .Name("ddlAlternateCategory")
                .DataTextField("CATEGORY")
                .DataValueField("EPAL_STATUS_CD")
                .OptionLabel("---Select Category---")
                .HtmlAttributes(new { style = "width: 100%" })
                //.Enable(Model.DRUG_NM.ToStringNullSafe().IndexOf("~") > -1 && ViewBag.EPALPageView == "EditDetail" ? false: true)
                //.Value(Model.ALTRNT_SVC_CAT)
                .Text(Model.ALTRNT_SVC_CAT)
                .Events(events => events.Change("DetailController.dropdown.ALTRNT_SVC_SUBCAT_Change").DataBound("DetailController.dropdown.ALTRNT_SVC_CATDataBound"))
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        read.Action("GetPIMSEPALCategoriesByProcCDDrugNM", "Home", new { Area = "EPAL" }).Data("DetailController.dropdown.param.ALTRNT_SVC_CAT");
                    });
                })
                )
            <input type="hidden" id="ddlAlternateCategory_hidden" value="@Model.ALTRNT_SVC_CAT" />
        </div>
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Alternate Sub Category:</label>
        <div class="col-lg-3">            
            <input type="hidden" id="ddlAlternateSubCategoryFirstLoadValue" value="@Model.ALTRNT_SVC_SUBCAT" />
            <input type="hidden" id="ddlAlternateSubCategoryOrignal" value="@Model.ALTRNT_SVC_SUBCAT" />
            @*<input type="text"  data-toggle="tooltip" class="form-control" id="txtAlternateSubCategory" value="@Model.ALTRNT_SVC_SUBCAT" readonly />*@
            @(Html.Kendo().DropDownList()                
                .Name("ddlAlternateSubCategory")
                .DataTextField("CATEGORY")
                .DataValueField("CATEGORY")
                .OptionLabel("---Select Sub Category---")
                .HtmlAttributes(new { style = "width: 100%" })
                //.Enable(String.IsNullOrEmpty(Model.ALTRNT_SVC_SUBCAT.ToStringNullSafe()) ? false : (Model.DRUG_NM.ToStringNullSafe().IndexOf("~") > -1 ? false: true))
                //.Enable(String.IsNullOrEmpty(Model.ALTRNT_SVC_CAT.ToStringNullSafe()) ? false : true)
                .Events(events => events.Change("DetailController.dropdown.ALTRNT_SVC_SUBCAT_Change").DataBound("DetailController.dropdown.ALTRNT_SVC_SUBCAT_DataBound"))
                .Value(Model.ALTRNT_SVC_SUBCAT)
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        read.Action("GetPIMSEPALCategoriesByProcCDDrugNM", "Home", new { Area = "EPAL" }).Data("DetailController.dropdown.param.ALTRNT_SVC_SUBCAT");
                    })
                    .ServerFiltering(true);
                })
                .AutoBind(false)
                .CascadeFrom("ddlAlternateCategory")
            )
        </div>

    </div>
