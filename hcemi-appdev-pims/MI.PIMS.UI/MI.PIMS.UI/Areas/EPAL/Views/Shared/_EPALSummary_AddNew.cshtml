            @(Html.Kendo().DatePicker()
                .Name("dpPAEffectiveDate")     
                .Min(Convert.ToDateTime("01/01/1900"))
                .Value(@Model.PRIOR_AUTH_EFF_DT)    
                .Format("MM/dd/yyyy")                
                .ParseFormats(new string[] {"MMddyyyy", 
                                            "MMddyy",
                                            "MM.dd.yyyy", 
                                            "MM.dd.yy",
                                            "MM.d.yyyy",
                                            "M.d.yy",
                                            "M.d.yyyy",
                                            "MM/dd/yyyy", 
                                            "MM/dd/yy",
                                            "MM/d/yyyy",
                                            "M/d/yy",
                                            "M/d/yyyy",
                                            "MM-dd-yyyy", 
                                            "MM-dd-yy",
                                            "MM-d-yyyy",
                                            "M-d-yy",
                                            "M-d-yyyy"
                                            })               
                //.Enable(((string)ViewData["PageType"] == @Roles.EPALReadOnly.ToString() ? false : true))
                .Enable((appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.EPALReadWrite))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.EPALAdmin))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.UMRAdmin))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.UMRReadWrite))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.CMPAdmin))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.CMPReadWrite))
                        || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.SuperAdmin))) ? true : false)
                .HtmlAttributes(new { style = "width: 100%", @class= "form-to-update", placeholder = "MM/dd/yyyy" })
            )
        </div>
        <label for="dpPAExpirationDate" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">PA Expiration Date:</label>
         <div id="divPAExpirationDate" class="col-lg-3" data-toggle="tooltip">
            <input type="hidden" id="dpPAExpirationDateOriginal" value="@Model.PRIOR_AUTH_EXP_DT" />
            @(Html.Kendo().DatePicker()
                .Name("dpPAExpirationDate")
                //.Min(String.IsNullOrEmpty(@Model.PRIOR_AUTH_EFF_DT.ToStringNullSafe()) ? "01/01/1900": Convert.ToDateTime(Model.PRIOR_AUTH_EFF_DT).AddDays(1).ToStringNullSafe())
                .Min(Convert.ToDateTime("01/01/1900"))
                .Value(@Model.PRIOR_AUTH_EXP_DT)                
                .Format("MM/dd/yyyy")
                .ParseFormats(new string[] {"MMddyyyy", 
                                            "MMddyy",
                                            "MM.dd.yyyy", 
                                            "MM.dd.yy",
                                            "MM.d.yyyy",
                                            "M.d.yy",
                                            "M.d.yyyy",
                                            "MM/dd/yyyy", 
                                            "MM/dd/yy",
                                            "MM/d/yyyy",
                                            "M/d/yy",
                                            "M/d/yyyy",
                                            "MM-dd-yyyy", 
                                            "MM-dd-yy",
                                            "MM-d-yyyy",
                                            "M-d-yy",
                                            "M-d-yyyy"
                                            })
            @*    .Enable(((string)ViewData["PageType"] == @Roles.EPALReadOnly.ToString() ? false : true))*@
                .Enable((appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.EPALReadWrite))
