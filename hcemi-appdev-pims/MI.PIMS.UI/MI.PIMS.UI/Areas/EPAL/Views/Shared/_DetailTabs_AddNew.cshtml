<script>
    $(document).ready(function () {
        const tabs = myTab.querySelectorAll(".nav-item");
        tabs.forEach(tab => {
            tab.addEventListener('click', (event) => {
                const appInsightsClient = new TelemetryLogger();
                if(appInsightsClient.isAppInsightsEnabled("Client.EPALNew")) {
                    var tabStr = event.target.innerText;
                    const logProperties = new LogInfo(event.target.id, MS_ID, "EPAL Add New Detail " + tabStr + " Tab click");
                    appInsightsClient.trackEvent('Client.EPALNew.' + tabStr.replaceAll(' ', ''), logProperties);
                }
            });
        });
    });
</script>