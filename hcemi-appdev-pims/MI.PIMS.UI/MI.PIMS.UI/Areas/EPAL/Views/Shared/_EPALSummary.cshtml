@model MI.PIMS.BO.Dtos.EPAL_Procedures_V_Dto
@using Kendo.Mvc.UI

<input type="hidden" id="EPAL_EXP_DT" class="EPAL_EXP_DT" value="@Model.OVERALL_EXP_DT"/>

<div class="container tab-section">
    <h5>
        EPAL Summary
    </h5>     
    <hr />
    <!-- Row 1 -->
    <div class="form-row my-row-padding">
        <label for="txtCodeStatus" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Procedure Code Status:</label>
        <div id="divCodeStatus" class="col-lg-2" data-toggle="tooltip">
            @*<input type="text" data-toggle="tooltip" class="form-control" id="txtCodeStatus" value="@Model.PROC_CD_STATUS" readonly="readonly">*@
            <span style="height: 25px; display: inline-block; vertical-align: text-bottom; width: 100%; padding-top: 5px;" class="label-tag-@(@Model.PROC_CD_STATUS == "Valid" ? "green": "red")">@Model.PROC_CD_STATUS</span>
        </div>
    </div>
    <!-- Row 2 -->
    <div class="form-row my-row-padding">
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">HCEMI Reporting Category:</label>
        <div class="col-lg-2">
            <input type="text"  data-toggle="tooltip" class="form-control" id="txtStandardCategory" value="@Model.STNDRD_SVC_CAT" readonly>
        </div>
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">HCEMI Reporting Subcategory:</label>
        <div class="col-lg-2">
            <input type="text"  data-toggle="tooltip" class="form-control" id="txtStandardSubCategory" value="@Model.STNDRD_SVC_SUBCAT" readonly>
        </div>
        <label for="txtCodeType" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Procedure Code Type:</label>
        <div class="col-lg-2">
            <input type="text" data-toggle="tooltip" class="form-control" id="txtCodeType" value="@Model.PROC_CD_TYPE" readonly="readonly">
        </div>
    </div>
    <!-- Row 3 -->
    <div class="form-row my-row-padding">
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight"> Alternate Category: </label>
        <div class="col-lg-2">
            <input type="text"  data-toggle="tooltip" class="form-control" id="txtAlternateCategory" value="@Model.ALTRNT_SVC_CAT" readonly />
        </div>
        <label class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Alternate Sub Category:</label>
        <div class="col-lg-2">
            <input type="text"  data-toggle="tooltip" class="form-control" id="txtAlternateSubCategory" value="@Model.ALTRNT_SVC_SUBCAT" readonly />
        </div>
        <label for="txtCodeDescription" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Procedure Code Description:</label>
        <div class="col-lg-2">
            <textarea class="form-control" data-toggle="tooltip" id="txtCodeDescription" rows="3" readonly="readonly">@Model.PROC_CD_DESC</textarea>
        </div>
    </div>    
    <!-- Row 4 -->
    <div class="form-row my-row-padding">
        <label id="lblPriorAuth" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">Prior Auth:</label>
        <div id="divPriorAuth" class="col-lg-2" data-toggle="tooltip">
            <input type="text" data-toggle="tooltip" class="form-control" readonly id="txtPriorAuth" name="txtPriorAuth" value="@Model.PRIOR_AUTH_IND">
        </div>
        <label for="dpPAEffectiveDate" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">PA Effective Date:</label>
        <div id="divPAEffectiveDate" class="col-lg-2" data-toggle="tooltip">
            @(Html.Kendo().DatePicker()
                .Name("dpPAEffectiveDate")
                .Value(@Model.PRIOR_AUTH_EFF_DT)
                .Format("MM/dd/yyyy")
                .ParseFormats(new string[] {"MMddyyyy",
                    "MMddyy",
                    "MM.dd.yyyy",
                    "MM.dd.yy",
                    "MM.d.yyyy",
                    "M.d.yy",
                    "M.d.yyyy",
                    "MM/dd/yyyy",
                    "MM/dd/yy",
                    "MM/d/yyyy",
                    "M/d/yy",
                    "M/d/yyyy",
                    "MM-dd-yyyy",
                    "MM-dd-yy",
                    "MM-d-yyyy",
                    "M-d-yy",
                    "M-d-yyyy"
                })
                .Enable(((string)ViewData["PageType"] == @Roles.EPALReadOnly.ToString() ? false : true))
                .HtmlAttributes(new { style = "width: 100%", @class = "form-to-update" })
                )
        </div>
        <label for="dpPAExpirationDate" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">PA Expiration Date:</label>
        <div id="divPAExpirationDate" class="col-lg-2" data-toggle="tooltip">
            @(Html.Kendo().DatePicker()
                .Name("dpPAExpirationDate")
                .Value(@Model.PRIOR_AUTH_EXP_DT)
                .Format("MM/dd/yyyy")
                .ParseFormats(new string[] {"MMddyyyy",
                    "MMddyy",
                    "MM.dd.yyyy",
                    "MM.dd.yy",
                    "MM.d.yyyy",
                    "M.d.yy",
                    "M.d.yyyy",
                    "MM/dd/yyyy",
                    "MM/dd/yy",
                    "MM/d/yyyy",
                    "M/d/yy",
                    "M/d/yyyy",
                    "MM-dd-yyyy",
                    "MM-dd-yy",
                    "MM-d-yyyy",
                    "M-d-yy",
                    "M-d-yyyy"
                })
                .Enable(((string)ViewData["PageType"] == @Roles.EPALReadOnly.ToString() ? false : true))
                .HtmlAttributes(new { style = "width: 100%", title = "PA_PROC_EXP_DT from EPAL_PA_PROCEDURES_T table", @class = "form-to-update" })
                )
        </div>
    </div>
    <!-- Row 5 -->
