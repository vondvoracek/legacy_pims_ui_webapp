                        @(Html.Kendo().DatePicker()
                            .Name("dpSOSEffectiveDate")
                            .Value(@Model.SOS_EFF_DT)
                            .Format("MM/dd/yyyy")
                            //.Min(@Model.PRIOR_AUTH_EFF_DT.ToStringNullSafe() == "" ? "1900/1/1": @Model.PRIOR_AUTH_EFF_DT.ToStringNullSafe())
                            //.Max(@Model.PRIOR_AUTH_EXP_DT.ToStringNullSafe() == "" ? "2099/12/12": @Model.PRIOR_AUTH_EXP_DT.ToStringNullSafe())
                            .ParseFormats(new string[] {"MMddyyyy", 
                                                        "MMddyy",
                                                        "MM.dd.yyyy", 
                                                        "MM.dd.yy",
                                                        "MM.d.yyyy",
                                                        "M.d.yy",
                                                        "M.d.yyyy",
                                                        "MM/dd/yyyy", 
                                                        "MM/dd/yy",
                                                        "MM/d/yyyy",
                                                        "M/d/yy",
                                                        "M/d/yyyy",
                                                        "MM-dd-yyyy", 
                                                        "MM-dd-yy",
                                                        "MM-d-yyyy",
                                                        "M-d-yy",
                                                        "M-d-yyyy"
                                                        })
                            .Enable((appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.EPALReadWrite))
                                    || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.EPALAdmin))
                                    || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.UMRAdmin))
                                    || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.UMRReadWrite))
                                    || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.CMPAdmin))
                                    || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.CMPReadWrite))
                                    || appRoles.Contains(Convert.ToString((int)MI.PIMS.UI.Roles.SuperAdmin)) ? true : (@Model.PRIOR_AUTH_IND.ToStringNullSafe() == "No" ? true : false)))

                            .HtmlAttributes(new { style = "width: 100%", @class= "form-to-update", ovalue=@Model.SOS_EFF_DT })
                            .Events(events => events.Change("DetailController.methods.SOSEffectiveDateChange"))
                        )
                    </div>
                    <label for="dpSOSExpirationDate" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight">SOS Expiration Date:</label>
