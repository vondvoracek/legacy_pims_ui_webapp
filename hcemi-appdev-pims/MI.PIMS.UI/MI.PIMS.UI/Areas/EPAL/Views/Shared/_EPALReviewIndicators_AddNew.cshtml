                    <label for="ddlSOSTypeReview" class="col-lg-2 text-lg-right text-sm-left col-form-label font-modal-weight sos-required-label @(Model.SOS_EFF_DT.ToString() == "" ? "" : "required")">SOS Type Review:</label>
