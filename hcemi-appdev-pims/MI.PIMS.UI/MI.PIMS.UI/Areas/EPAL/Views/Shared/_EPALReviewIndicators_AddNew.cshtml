                                                        "MMddyy",
                                                        "MM.dd.yyyy", 
                                                        "MM.dd.yy",
                                                        "MM.d.yyyy",
                                                        "M.d.yy",
                                                        "M.d.yyyy",
                                                        "MM/dd/yyyy", 
                                                        "MM/dd/yy",
                                                        "MM/d/yyyy",
                                                        "M/d/yy",
                                                        "M/d/yyyy",
                                                        "MM-dd-yyyy", 
                                                        "MM-dd-yy",
                                                        "MM-d-yyyy",
                                                        "M-d-yy",
                                                        "M-d-yyyy"
                                                        })
