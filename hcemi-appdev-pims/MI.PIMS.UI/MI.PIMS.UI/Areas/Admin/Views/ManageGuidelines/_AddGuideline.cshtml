@using Kendo.Mvc.UI

<div class="addGuidelineWindow" id="addGuidelineWindow">
    <form id="formAddNew" onsubmit="return false;">
        <div>
            <div class="form-row my-row-padding">
                <div class="col-lg-5">
                    <label for="txtProcedureCodeAddNew" class="text-lg-right text-sm-left col-form-label font-modal-weight required">Procedure Code:</label>
                    <div>
                        <input type="text" class="form-control" id="txtProcedureCodeAddNew" placeholder="Press Enter to add into below list to save" />
                    </div>
                    <div>
                        @(Html.Kendo().ListView<string>()
                        .Name("lsvProcedureCodes")
                        .TagName("div")
                        .ClientTemplateId("lsvProcedureCodes_Template")
                        .HtmlAttributes(new { style = "height:250px;overflow-y:auto" })
                        .AutoBind(false)
                        )
                        <script type="text/x-kendo-tmpl" id="lsvProcedureCodes_Template">
                            <div>
                                <span class="badge badge-primary ml-2">#:PROC_CD#</span>
                            </div>
                        </script>
                    </div>
                </div>
                <div class="col-lg-7">
                    <!-- Row 1 -->
                    <div class="form-row my-row-padding">
                        <label for="txtIQReferenceAddNew" class="col-lg-5 text-lg-right text-sm-left col-form-label font-modal-weight required">IQ Reference:</label>
                        <div class="col-lg-7">
                            <input type="text" class="form-control" id="txtIQReferenceAddNew" />
                        </div>
                    </div>
                    <!-- Row 2 -->
                    <div class="form-row my-row-padding">
                        <label for="txtIQGuidelineIDAddNew" class="col-lg-5 text-lg-right text-sm-left col-form-label font-modal-weight required">IQ Guideline ID:</label>
                        <div class="col-lg-7">
                            <input type="text" class="form-control" id="txtIQGuidelineIDAddNew" />
                        </div>
                    </div>
                    <!-- Row 3 -->
                    <div class="form-row my-row-padding">
                        <label for="txtIQVersionAddNew" class="col-lg-5 text-lg-right text-sm-left col-form-label font-modal-weight required">IQ Version:</label>
                        <div class="col-lg-7">
                            <input type="text" class="form-control" id="txtIQVersionAddNew" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

@*         <!-- Status Label -->
        <div id="AddGuidelineStatus" class="alert alert-warning d-none" role="alert" style="font-size:14px;">
            <strong>Error:</strong> At least one field of search criteria must be populated.
            <button type="button" class="close" aria-label="Close" onclick="$('#AddGuidelineStatus').addClass('d-none');">
                <span aria-hidden="true">&times;</span>
            </button>
        </div> *@

        <div class="d-flex justify-content-end">
            <button id="btnValidateGuideline" type="button" class="btn btn-primary noSubmit btnValidateGuideline mr-2">
                <i class="fas fa-save"></i> Validate
            </button>
            <button type="reset" id="btnResetAddNewGuideline" class="btn btn-secondary mr-2">Reset</button>
            <button type="button" id="btnCloseAddNewGuideline" class="btn btn-secondary">Close</button>
        </div>
    </form>
</div>
