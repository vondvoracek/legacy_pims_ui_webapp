@using Kendo.Mvc.UI

<script src="~/js/Admin/_activeDirectorySearch.js" asp-append-version="true"></script>

<form id="AD_searchForm">

<div id="activeDirectorySearchModal" class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="activeDirectorySearchModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content" style="width: 890px;">
            <div class="modal-header">
                <h5 class="modal-title">Active Directory Search</h5>
                <button type="button" class="close noSubmit" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row form-group">
                    <div class="col-12">
                        <label style="font-size:11px;">
                            Enter MSID, First or Last name to search Active Directory. <br />
                            Max result count is 20 records. To get better results, please narrow down your search parameters.
                        </label>
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-3" style="text-align: right;">
                        <label>MS ID:</label>
                    </div>
                    <div class="col-7">
                        <input type="text" id="txtMS_ID_ADSearch" class="k-textbox form-control">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-3" style="text-align: right;">
                        <label>First Name:</label>
                    </div>
                    <div class="col-7">
                        <input type="text" id="txtFname_ADSearch" name="First Name" class="k-textbox form-control">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-3" style="text-align: right;">
                        <label>Last Name:</label>
                    </div>
                    <div class="col-7">
                        <input type="text" id="txtLname_ADSearch" class="k-textbox form-control">
                    </div>
                </div>
                <div class="row form-group">
                    <div class="col-md-12">
                        <div style="text-align:center; padding-bottom:12px;">
                            <hr />
                            <button id="btnAddUserSearch_ADSearch" type="button" class="btn btn-outline-info noSubmit"><i class="fas fa-search"></i> Search Active Directory </button>
                        @*     <button id="btnAzureAD" type="button" class="btn btn-outline-info noSubmit"><i class="fas fa-search"></i> Search Azure Active Directory </button> *@
                            <button id="btnAddUserReset_ADSearch" type="button" class="btn btn-primary noSubmit"><i class="fas fa-redo-alt"></i> Reset  </button>
                            <button id="btnAddUserClose_ADSearch" type="button" class="btn btn-default btn-outline-primary  my-button noSubmit" data-dismiss="modal"><i class="fas fa-arrow-circle-left"></i> Close </button>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-12">
                        <div style="font-size:11px;">
                            @(Html.Kendo().Grid< MI.PIMS.BO.Dtos.ActiveDirectoryUserDto> () // Specify the type of the grid
                            .Name("grid_ADSearch")
                            .Columns(columns =>
                            {
                                columns.Bound(c => c.MS_ID).Title("MSID").Width(100);
                                columns.Bound(c => c.First_Name).Title("First Name");
                                columns.Bound(c => c.Last_Name).Title("Last Name");
                                columns.Bound(c => c.Email).Title("Email Address");
                                columns.Bound(c => c.Division_Name).Title("Department");
                                columns.Bound(c => c.MS_ID).Title(" ")
                                .ClientTemplate("<button type='button' title='Click to add new user!' class='btn btn-default btn-outline-primary' onclick=\'_activeDirectorySearchController.methods.addUserInfo(this)\'><i class='fa fa-plus fa-1x\' aria-hidden='true'></i></button>")
                                .HeaderHtmlAttributes(new { style = "text-align: center" })
                                .HtmlAttributes(new { style = "text-align: center" })
                                .Width(65);
                            })
                                .AutoBind(false)
                                .NoRecords()
                                .Pageable()
                                    .HtmlAttributes(new { style = "height: 300px;width:860px" })
                                    .Sortable()
                                    .Scrollable()
                                    //.Filterable()
                                    .DataSource(dataSource => dataSource
                                        .Ajax()
                                        .PageSize(50)
                                        .Read(read => read.Action("GetActiveDirectoryUser2", "Home").Data("_activeDirectorySearchController.grid.param"))
                                )
                            )
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="col-6 text-right" style="padding-bottom:30px;">
                </div>
            </div>
        </div>
    </div>
</div>

</form>
<style>
    .fa-plus-circle {
        cursor: pointer;
    }

    .top10 {
        margin-top: 10px;
    }
</style>


