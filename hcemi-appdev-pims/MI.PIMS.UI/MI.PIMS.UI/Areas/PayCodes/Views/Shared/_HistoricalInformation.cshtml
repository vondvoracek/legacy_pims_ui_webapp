@using Kendo.Mvc.UI
@{
    ViewData["Title"] = "Pay Code - Historical Information";
}

<style>
.edit-epal-icon{
    cursor:pointer;font-size: 15px;margin-top: 4px;
}

.edit-epal-icon:hover {
    transform: scale(1.3);
}
</style>


<div class="container tab-section">
    <h5>
        Historical Information
    </h5>
    <hr />
    <form id="frmHistoricalInformation">

        <div class="form-row">
            <div class="form-group col-md-12">
                <div style="font-size:11px !important;">
                    @(
                        Html.Kendo().Grid<MI.PIMS.BO.Dtos.PayCode_Procedures_V_Dto>()
                            .Name("gridPayCodeHistorical")
                            .Columns(c =>
                            {

                                c.Bound(p => p.PAYC_STATUS).Title("Pay Code<br/>Status").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
                              //c.Bound(p => p.PAYC_HIERARCHY_KEY).Title("Pay Code ID").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(200);

                                c.Bound(p => p.PAYC_HIERARCHY_KEY)
                                    .Title("Pay Code ID")
                                    .ClientTemplate(
                                        "<a href='javascript:void(0);' style='color:blue;' onclick=\"PayCodeSummaryController.methods.redirect_PayCode('#= PAYC_HIERARCHY_KEY#,#= kendo.toString(kendo.parseDate(PAYC_VER_EFF_DT),'MM-dd-yyyy hh:mm:ss tt') #');\" title='Click to view details!' \\data-target='tooltip'\\>#= PAYC_HIERARCHY_KEY # </a>"
                                     )
                                .Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                                .HtmlAttributes(new { style = "text-align: center" }).Width(200);
                                
                                
                                
                                
                                c.Bound(p => p.PAYC_KL_PCS).Title("KL PCS").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
                                c.Bound(p => p.PAYC_NDB_PCS).Title("NDB PCS").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
                                c.Bound(p => p.PAYC_NDB_REMARK_CD).Title("NDB Remark<br/>Code").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(60);
                                c.Bound(p => p.PAYC_ICES_IND).Title("Clinical<br/>iCES/CES").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(80);
                                c.Bound(p => p.PAYC_ICES_EDIT_NAME).Title("Clinical<br/>iCES/CES<br/>Edit Name").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(120);
                                c.Bound(p => p.PAYC_ICES_EDIT_ACTION).Title("Clinical<br/>iCES/CES<br/>Edit Action").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
                                c.Bound(p => p.PAYC_MCR_ROUTED).Title("Routed<br/> to MCR").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(100);
                                c.Bound(p => p.PAYC_ADVN_NOTIF).Title("Advanced<br/>Notification<br/>Required?").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(80);
                            c.Bound(p => p.PAYC_VER_EFF_DT).Filterable(false)
                                .Title("Pay Code Ver<br/>Eff Date")
                            .ClientTemplate("#= ( kendo.toString(kendo.parseDate(PAYC_VER_EFF_DT), 'MM/dd/yyyy hh:mm:ss tt') == '12/31/2999' || (data.PAYC_VER_EFF_DT == null)) ? ' ' : kendo.toString(kendo.parseDate(PAYC_VER_EFF_DT), 'MM/dd/yyyy hh:mm:ss tt') #")
                                .HtmlAttributes(new { style = "text-align: center" })
                                .HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                                .Width(100);

                            c.Bound(p => p.ROW_NUMBER)
                            .ClientTemplate("#if(ROW_NUMBER==1) {#<i style='color:teal;' class='fas fa-check-circle 3x'></i> #} else {# <i style='color:red;' class='fas fa-times 3x'></i> #} #")
                                .Title("<b>Current <br/>Record</b>")
                                .Width(80)
                                .HtmlAttributes(new { style = "text-align:center" })
                                .HeaderHtmlAttributes(new { style = "text-align:center" })
                                .Filterable(false);
                            })
                            .Resizable(resize => resize.Columns(true))
                            .HtmlAttributes(new { style = "height: 100%" })
                            .Sortable()
                            .NoRecords()
                            .Navigatable()
                            .Pageable(pageable => pageable
                            .Refresh(true)
                            .PreviousNext(true)
                            .Numeric(true)
                            )
                            .AutoBind(true)
                            .Scrollable()
                            .Selectable()
                            .Filterable()
                            .DataSource(dataSource => dataSource
                            .Ajax()
                            .PageSize(100)
                            .Read(read => read.Action("GetPayCodeHistorical", "Home", new { Area = "PayCodes" }).Data("PayCodeSummaryController.grid.param"))
                            )
                        )
                </div>
            </div>
        </div>
    </form>
</div>