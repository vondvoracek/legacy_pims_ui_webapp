                        <span>Include Historical Records</span> &nbsp;
                        @(Html.Kendo().Switch()
                            .Name("switch")
                            .Events(ev => ev.Change("SearchController.switch.onChange"))
                            .HtmlAttributes(new { style = "width: 100%" })
                            .Checked(true)
                            .Messages(c => c.Checked("YES").Unchecked("NO"))
                            )
