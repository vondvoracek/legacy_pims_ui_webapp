                    .HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                    .Width(100);
                c.Bound(p => p.PAYC_VER_EFF_DT).Filterable(false)
                    .Title("Pay Code Ver<br/>Eff Date")
                    .ClientTemplate("#= ( kendo.toString(kendo.parseDate(PAYC_VER_EFF_DT), 'MM/dd/yyyy hh:mm:ss tt') == '12/31/2999' || (data.PAYC_VER_EFF_DT == null)) ? ' ' : kendo.toString(kendo.parseDate(PAYC_VER_EFF_DT), 'MM/dd/yyyy hh:mm:ss tt') #")
                    .HtmlAttributes(new { style = "text-align: center" })
                    .HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" })
                    .Width(100);
                c.Bound(p => p.ROW_NUMBER).ClientTemplate("<span id='lblRowNum'>#= data.ROW_NUMBER#</span>").Title("Row Number").Hidden(true);
                //c.Bound(p => p.PAYC_BUS_SEG_CD).Title("Bus Seg").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(65);
                //c.Bound(p => p.PAYC_ENTITY_CD).Title("Entity").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(65);
                //c.Bound(p => p.PAYC_PLAN_CD).Title("Plan").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(65);
                //c.Bound(p => p.PAYC_PRODUCT_CD).Title("Product").Filterable(false).HeaderHtmlAttributes(new { style = "text-align: center; font-weight:bold" }).HtmlAttributes(new { style = "text-align: center" }).Width(65);
            
              


           
            })
            .Resizable(resize => resize.Columns(true))
            .HtmlAttributes(new { style = "height: 100%" })
            .Sortable()
            .Events(e => e.ExcelExport("SearchController.grid.excelExport")
            .DataBound("SearchController.grid.onDataBound")
            )
            .Navigatable()
            .ToolBar(tools => tools.Excel())
            .Pageable(pageable => pageable
            .Refresh(true)
            .PreviousNext(true)
            .Numeric(true)
            )
            .AutoBind(false)
            .Scrollable()
            .Selectable()
            .Filterable()
            .Excel(excel => excel
            .AllPages(true)
            .FileName("ExportExcel.xlsx")
            .Filterable(true)
            .ProxyURL(Url.Action("Excel_Export_Save", "Grid"))
            )
            .DataSource(dataSource => dataSource
            .Ajax()
            .PageSize(100)
            .Read(read => read.Action("GetPayCodeProceduresSearch", "Home").Data("SearchController.grid.param"))
            .Events(ev => ev.RequestEnd("SearchController.grid.onGridRequestEnd"))
            .ServerOperation(false)
            )
            )
    </div>


</div>

