                    .ClientTemplate("#= ( kendo.toString(kendo.parseDate(PAYC_EXP_DT), 'MM/dd/yyyy') == '12/31/2999'  || (data.PAYC_EFF_DT == null)) ? ' ' : kendo.toString(kendo.parseDate(PAYC_EXP_DT), 'MM/dd/yyyy') #")
