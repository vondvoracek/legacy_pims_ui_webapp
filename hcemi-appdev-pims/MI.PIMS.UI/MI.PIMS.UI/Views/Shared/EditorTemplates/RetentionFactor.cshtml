@using Kendo.Mvc.UI
@model MI.PIMS.BO.Dtos.Ret_Factor_DD_Dto


@(Html.Kendo().MultiColumnComboBoxFor(m => m)           
    //.AutoBind(false)
    //.MinLength(2)
    .DataTextField("FACTOR_DESC_RET")
    .DataValueField("FACTOR_NM_RET")
    .Filter("contains")    
    .IgnoreCase(true)
    .FilterFields(new string[] { "FACTOR_NM_RET" })
    .Placeholder("Please select Retention code(s)/Description...")
    .Columns(columns =>
    {
        columns.Add().Field("FACTOR_NM_RET").Title("Code").Width("100px");
        columns.Add().Field("FACTOR_DESC_RET").Title("Description").Width("400px");
    })                
    .HtmlAttributes(new { style = "width:100%;", data_value_primitive = "true", required="required"})
    .Height(400)    
    .DataSource(source =>  source
        .Custom()
        .Transport(transport => transport
        .Read(read =>
        {
            read.Action("GetRetentionFactors", "Home", new { Area = "EPAL" });
        }))
    )
)

<script>
$(document).ready(function() {    
    var retention_mcc = $("#FACTOR_NM_RET").data("kendoMultiColumnComboBox");
    retention_mcc.bind("select", onSelect);
    retention_mcc.bind("close", onClose);

    function onSelect(e) {        
        if (e.dataItem) {
            var dataItem = e.dataItem;
            var grid = $(this.element).closest("tr").closest(".k-grid").data("kendoGrid")
            var gridModel = grid.dataItem($(this.element).closest("tr"))          
            
            //Check if data base been already entered with same DIAG_CD in the grid
            if (isDuplicateFACTOR_NM(grid, dataItem.FACTOR_NM_RET)) {
            
                MICore.Notification.warning('Duplicate entries', 'Selected Retention code already exists!');                
                _RetRedFactorController.gridRetention.deleteRowSilently(e);
            
            } else {
                if (dataItem.FACTOR_NM_RET != '') { 
                    gridModel.FACTOR_NM_RET = dataItem.FACTOR_NM_RET;
                }
                gridModel.FACTOR_DESC_RET = dataItem.FACTOR_DESC_RET;
            }            
            grid.refresh();
            DetailController.dirtyform.dirtycheck();
        }
    };

    function onClose(e) {
        var grid = $(this.element).closest("tr").closest(".k-grid").data("kendoGrid")
        var gridModel = grid.dataItem($(this.element).closest("tr"))        
        if (e.dataItem == undefined && (gridModel.FACTOR_NM_RET == '' || gridModel.FACTOR_NM_RET == undefined))
        {
            refreshFACTOR_NM(this.element);
        }
    };

    function isDuplicateFACTOR_NM(grid, value) {        
        var data = grid.dataSource._data;
        var duplicate = false;
        jQuery.each(data, function (index, rowData) {
            if (rowData.FACTOR_NM_RET == value) {
                return duplicate = true;    
            }
        });

        return duplicate;
    }

    function refreshFACTOR_NM(element){                
        var $FACTOR_NM = $("#FACTOR_NM_RET").data("kendoMultiColumnComboBox");
        var grid = $(element).closest("tr").closest(".k-grid").data("kendoGrid");
        var gridModel = grid.dataItem($(element).closest("tr"));      

        gridModel.FACTOR_NM_RET = '';
        gridModel.FACTOR_DESC_RET = '';

        $FACTOR_NM.select(-1);
        $FACTOR_NM.refresh();
    }
});
</script>