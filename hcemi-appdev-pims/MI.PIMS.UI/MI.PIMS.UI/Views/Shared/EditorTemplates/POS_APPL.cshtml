@using Kendo.Mvc.UI;
@using MI.PIMS.BO.Dtos
@model MI.PIMS.BO.Dtos.POS_APPL_Dto

@(Html.Kendo().MultiColumnComboBoxFor(m => m)
    .DataTextField("POS_APPL_DESC")
    .DataValueField("POS_APPL")
    .Filter("contains")
    .FilterFields(new string[] { "POS_APPL_DESC", "POS_APPL" })
    .Columns(columns =>
    {
        columns.Add().Field("POS_APPL").Title("Code").Width("200px");
        columns.Add().Field("POS_APPL_DESC").Title("Description").Width("300px");
    })
    .HtmlAttributes(new { style = "width:100%;", data_value_primitive = "true" })
    .Height(400)
    .DataSource(source =>
    {
        source.Read(read =>
        {
            read.Action("GetPOS_APPL", "GuidelineSummary", new { Area = "DPOC" });
        })
        .ServerFiltering(false);
    })
)

<script>
    $(document).ready(function () {
        var dtq_rsn = $("#POS_APPL").data("kendoMultiColumnComboBox");
        dtq_rsn.bind("select", onPLC_OF_SVCSelect);

        function onPLC_OF_SVCSelect(e) {
            //debugger;
            if (e.dataItem) {
                var dataItem = e.dataItem;
                var grid = $(this.element).closest("tr").closest(".k-grid").data("kendoGrid")
                var gridModel = grid.dataItem($(this.element).closest("tr"))

                /*
                if (isDuplicatePOS(grid, dataItem.POS_APPL)) {

                    MICore.Notification.warning('Duplicate entries', 'Selected POS already exists!');
                    DiagCodesController.grid.deleteRowSilently(e);

                } else {
                    if (dataItem.POS_APPL != '') {
                        gridModel.POS_APPL = dataItem.POS_APPL;
                    }
                    gridModel.POS_APPL_DESC = dataItem.POS_APPL_DESC;
                }*/
                if (dataItem.POS_APPL != '') {
                    gridModel.POS_APPL = dataItem.POS_APPL;
                }
                gridModel.POS_APPL_DESC = dataItem.POS_APPL_DESC;

                grid.refresh();
                DetailController.dirtyform.dirtycheck();
            }
        };

        function isDuplicatePOS(grid, value) {
            var data = grid.dataSource._data;
            var dupPos = false;
            jQuery.each(data, function (index, rowData) {
                if (rowData.POS_APPL == value) {
                    return dupPos = true;
                }
            });

            return dupPos;
        }
    });
</script>