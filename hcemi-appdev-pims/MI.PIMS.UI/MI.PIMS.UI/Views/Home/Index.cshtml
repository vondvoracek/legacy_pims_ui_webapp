@{
    ViewData["Title"] = "Home";
}

<style type="text/css">
    .ul-in-out-scope-text {
        font-size: 12px;
    }

</style>

<div class="jumbotron" style="padding-left:20px;height:auto;">
    <div class="container">
        <div style="margin-top:-10px;">
            <h5>HCE Medical Informatics</h5>
            <h3>Welcome to Policy Integration Management System (PIMS)</h3>
            <br />
            <p class="lead">
                PIMS is a web application that allows users to search, add/update policy information.  
            </p>
            <p class="lead">Click on a menu option to get started!</p>
        </div>

    </div>
</div>
<div class="container">
    <span style="color:#424242; padding-left:25px; font-size:22px;">Select a Menu Option</span>
    <div style="padding-left:10px; margin-top:10px;">
        @await Component.InvokeAsync("MenuPanel")
    </div>
</div>










